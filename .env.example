# 环境变量配置文件示例
# 复制此文件为 .env 并填入实际值

# 管理员密码哈希 - 优先使用环境变量
# 生成命令: node -e "require('bcrypt').hash('your_password', 10).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$10$kuGiWd4E/x1k1uPwaoHa5OfiAB60.kTDtmvpT9W2wUqskTETrojPm

# 服务器端口 (可选)
PORT=3000

# CORS设置 (可选)
CORS_ORIGIN=http://localhost:3000

# 加密密钥 (可选，用于其他安全功能)
JWT_SECRET=your_jwt_secret_key_here

# 日志级别 (可选)
LOG_LEVEL=info